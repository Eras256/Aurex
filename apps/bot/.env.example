# Core server
PORT=3001                 # Internal HTTP/WS port for the bot
NODE_ENV=development

# Simple API key to protect config/reset endpoints
API_KEY=dev-api-key-12345

# Binance (REST + WebSocket)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com

# Kraken (REST + WebSocket)
KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_REST_URL=https://api.kraken.com

# Coinbase Advanced Trade, OKX, Bybit (public WebSocket market data, no auth required)
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/spot

# Supabase Postgres (used only by the bot)
# Placeholders are provided below. Uncomment and configure to enable cloud logging.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Persistence driver: "local" uses db.json, "supabase" uses Supabase Postgres
PERSISTENCE_DRIVER=local

# Engine defaults (optional overrides). The L2 depth-walk already prices real slippage,
# so the extra slippage cushion is 0; a 1bp latency buffer models WS transit drift.
ENGINE_MIN_NET_PROFIT_USD=0.25
ENGINE_MAX_POSITION_BTC_PER_EXCHANGE=2.0
ENGINE_MAX_POSITION_QUOTE_PER_EXCHANGE=100000
ENGINE_LATENCY_SAFETY_BPS=1
ENGINE_SLIPPAGE_SAFETY_BPS=0
# Stablecoin (USD<->USDT) basis cost in bps, charged only on legs that cross quote
# currencies (e.g. Coinbase BTC-USD vs Binance BTC-USDT). 3 bps ≈ realistic USDC/USDT
# conversion cost. Set 0 to treat USD≈USDT 1:1.
ENGINE_USDT_USD_BASIS_BPS=3
ENGINE_MAX_TRADES_PER_MINUTE=30

# --- Live testnet / demo execution (OPTIONAL) ---------------------------------
# Leave empty for simulation-only. When set AND the engine runs in executionMode
# "testnet" (toggle in the Risk page), windows whose both legs are on a configured
# venue (Binance / OKX / Bybit / Coinbase) are executed as REAL IOC orders against
# the venues' TEST environments (fake balances, no real funds).
# Never commit real keys; these are testnet/demo keys only.
#
# Binance Spot Testnet — create a key at https://testnet.binance.vision (GitHub login)
BINANCE_TESTNET_REST_URL=https://testnet.binance.vision
# BINANCE_TESTNET_API_KEY=your-binance-testnet-key
# BINANCE_TESTNET_API_SECRET=your-binance-testnet-secret
#
# OKX Demo Trading — create a key flagged "demo" in your OKX account
OKX_REST_URL=https://www.okx.com
# OKX_DEMO_API_KEY=your-okx-demo-key
# OKX_DEMO_API_SECRET=your-okx-demo-secret
# OKX_DEMO_PASSPHRASE=your-okx-demo-passphrase
#
# Bybit Testnet — create a key at https://testnet.bybit.com
BYBIT_TESTNET_REST_URL=https://api-testnet.bybit.com
# BYBIT_TESTNET_API_KEY=your-bybit-testnet-key
# BYBIT_TESTNET_API_SECRET=your-bybit-testnet-secret
#
# Coinbase Exchange Sandbox — create a key at https://public-sandbox.exchange.coinbase.com
# (real matching engine, test funds). Secret is base64; passphrase is set at key creation.
COINBASE_SANDBOX_REST_URL=https://api-public.sandbox.exchange.coinbase.com
# COINBASE_SANDBOX_API_KEY=your-coinbase-sandbox-key
# COINBASE_SANDBOX_API_SECRET=your-coinbase-sandbox-secret
# COINBASE_SANDBOX_PASSPHRASE=your-coinbase-sandbox-passphrase
#
# Kraken has NO spot testnet — these real keys are used ONLY for validate=true dry-run
# order validation (checks the order, never executes, never returns a txid; moves no funds).
# KRAKEN_API_KEY=your-kraken-api-key
# KRAKEN_API_SECRET=your-kraken-api-secret
