# ==============================================================================
# Master Environment Variables Template - Aurex
# ==============================================================================
#
# This file serves as master documentation. Actual applications read from their 
# respective directory env files:
#   - Backend: apps/bot/.env
#   - Frontend: apps/web/.env.local
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BACKEND SIMULATOR ENGINE (apps/bot/.env)
# ------------------------------------------------------------------------------

# Core server configs
PORT=3001
NODE_ENV=development

# Simple API key to protect config/reset endpoints
API_KEY=dev-api-key-12345

# Binance API Credentials & Streams (REST + WebSocket)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com

# Kraken API Credentials & Streams (REST + WebSocket)
KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_REST_URL=https://api.kraken.com

# Supabase Postgres Integration (Used ONLY by the backend bot)
# Uncomment these in apps/bot/.env and change PERSISTENCE_DRIVER=supabase to log trades in the cloud
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-or-secret-key

# Database Persistence Mode ("local" -> db.json, "supabase" -> Supabase Postgres)
PERSISTENCE_DRIVER=local

# Central Arbitrage Engine Overrides
ENGINE_MIN_NET_PROFIT_USD=1.5
ENGINE_MAX_POSITION_BTC_PER_EXCHANGE=0.5
ENGINE_MAX_POSITION_QUOTE_PER_EXCHANGE=10000
ENGINE_LATENCY_SAFETY_BPS=5
ENGINE_SLIPPAGE_SAFETY_BPS=2
ENGINE_MAX_TRADES_PER_MINUTE=30

# ------------------------------------------------------------------------------
# 2. FRONTEND DASHBOARD PORTAL (apps/web/.env.local)
# ------------------------------------------------------------------------------

# Single base URL of the backend bot. The dashboard reads ONLY this variable
# (apps/web/app/WebSocketContext.tsx) and derives BOTH the REST base and the
# WebSocket connection from it (scheme swapped http->ws / https->wss, connected
# at the ROOT host — there is NO /ws path).
#   - Local:      http://localhost:3001
#   - Production: set in Vercel to https://bitcoin-arbitrage-bot.fly.dev
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
